<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishAot>true</PublishAot>
    <NativeLib>Shared</NativeLib>
    <AssemblyName>driver_openmeow</AssemblyName>
    <RootNamespace>OpenMeow.Driver</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <OptimizationPreference>Size</OptimizationPreference>
    <StackTraceSupport>false</StackTraceSupport>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\OpenMeow.Common\KeyBindings.cs" Link="KeyBindings.cs" />
    <Compile Include="..\OpenMeow.Common\MotionSettings.cs" Link="MotionSettings.cs" />
    <Compile Include="..\OpenMeow.Common\BodyGaitKernel.cs" Link="BodyGaitKernel.cs" />
  </ItemGroup>

</Project>
